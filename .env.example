# HumanEnv Server - Environment Configuration Example
# Copy this file to .env and customize for your deployment

# ============================================================
# Remote Deployment (manage.js)
# ============================================================

REMOTE_HOST_USER=root
REMOTE_HOST=188.245.71.48
REMOTE_HOST_PORT=22
REMOTE_HOST_PATH=/apps/humanenv
REMOTE_DOMAIN_HOST=188.245.71.48
REMOTE_SERVICE_IP=http://humanenv-server:3056
APP_NAME=humanenv
REMOTE_SYNC_EXCLUDES=data,node_modules,*.local,.git
REMOTE_DOMAIN_CONFIG_FILENAME=humanenv.yml
PUBLISHED_DOMAIN=https://humanenv.intrane.fr
MODE=staging
COMPOSE_FILE=compose.prod.yml

# ============================================================
# Server Configuration
# ============================================================

# Server port (default: 3056)
PORT=3056

# ============================================================
# Database Configuration
# ============================================================

# SQLite mode: Leave empty or comment out
# MONGODB_URI=

# MongoDB mode: Set your MongoDB connection string
# MONGODB_URI=mongodb://mongo:27017/humanenv
# MONGODB_URI=mongodb://user:password@localhost:27019/humanenv?authSource=admin

# ============================================================
# Private Key Management (CRITICAL)
# ============================================================

# Generate a 12-word mnemonic on first setup and store it securely
# This allows the server to auto-restore the private key after restarts
# WARNING: If lost, all encrypted data is unrecoverable!
# HUMANENV_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# ============================================================
# Admin UI Authentication
# ============================================================

# Basic auth credentials for admin UI
# CHANGE THESE FROM DEFAULTS IN PRODUCTION!
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=change-this-to-a-strong-password

# ============================================================
# HTTPS/TLS Configuration (Optional)
# ============================================================

# Enable HTTPS by setting certificate paths
# Certificates must be mounted via docker-compose volumes
# HTTPS_CERT_PATH=/certs/server.crt
# HTTPS_KEY_PATH=/certs/server.key

# ============================================================
# Advanced Configuration
# ============================================================

# PBKDF2 iterations for PK derivation (default: 100000)
# PBKDF2_ITERATIONS=100000

# Data directory inside container (default: /data/humanenv)
# DATA_DIR=/data/humanenv
